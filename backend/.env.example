# Copy to ".env" in this folder (backend/.env). Real ".env" is gitignored.
# Run the API from the backend directory:  mvn spring-boot:run
#
# ── Local SQLite (default) ─────────────────────────────────────────
# Leave SPRING_PROFILES_ACTIVE unset or use "local" — uses pos.db (no Supabase).

# ── Supabase (PostgreSQL) ───────────────────────────────────────────
# 1) Supabase Dashboard → Project Settings → Database
# 2) Under "Connection string", choose URI, then switch to "JDBC" if shown, or build:
#    jdbc:postgresql://db.<YOUR-PROJECT-REF>.supabase.co:5432/postgres?sslmode=require
#    (Direct connection, port 5432 — fine for local dev and small pools.)
# 3) Password: Database password from the same page (not your Supabase login).
#
# Optional: Session pooler (IPv4 / serverless-friendly), port 6543 — use the host/user Supabase shows for "Session pooler".

SPRING_PROFILES_ACTIVE=prod
DATABASE_URL=jdbc:postgresql://db.xxxxx.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-database-password

JWT_SECRET=change-me-to-a-long-random-secret
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_ORIGIN_PATTERNS=
AUTH_SETUP_ENABLED=false
AUTH_PUBLIC_SIGNUP_ENABLED=true
JWT_ACCESS_TOKEN_EXPIRATION=900000
AUTH_REFRESH_TOKEN_EXPIRATION=1209600000
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here
