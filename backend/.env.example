# Local: omit SPRING_PROFILES_ACTIVE or set to "local" (SQLite file pos.db).
# Production (Supabase): set SPRING_PROFILES_ACTIVE=prod and JDBC URL with sslmode=require.
SPRING_PROFILES_ACTIVE=local

# Supabase PostgreSQL — Project Settings → Database → Connection string (URI).
# JDBC form: jdbc:postgresql://db.<ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=jdbc:postgresql://db.xxxxx.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-database-password

JWT_SECRET=change-me-to-a-long-random-secret
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
AUTH_SETUP_ENABLED=false
AUTH_PUBLIC_SIGNUP_ENABLED=true
JWT_ACCESS_TOKEN_EXPIRATION=900000
AUTH_REFRESH_TOKEN_EXPIRATION=1209600000
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here
